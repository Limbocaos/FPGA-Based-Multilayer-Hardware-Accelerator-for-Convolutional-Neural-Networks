ENTITY 	top_convolution IS
    PORT (
	clk : IN std_logic;
	reset : IN std_logic;
	start : IN std_logic;
	effective_K : IN std_logic_vector(1 DOWNTO 0);
	effective_F : IN std_logic_vector(1 DOWNTO 0);
	stride_in : IN std_logic_vector(2 DOWNTO 0);
	padding_in : IN std_logic_vector(1 DOWNTO 0);
	activation_type : IN std_logic;
	coeffs_load_en : IN std_logic;
	coeffs_load : IN std_logic_vector(242 DOWNTO 0);
	pixel_in : IN std_logic_vector(8 DOWNTO 0);
	pixel_out : BUFFER std_logic_vector(53 DOWNTO 0);
	data_valid : BUFFER std_logic;
	done : BUFFER std_logic
	);
END top_convolution;

